# ============================================================
# JARVIS OS — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=8192

# --- Supabase ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
SECRET_KEY=troque-por-uma-chave-secreta-segura-aqui

# --- Frontend (para CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Voice Pipeline ---
WHISPER_MODEL=base
# Opções: tiny, base, small, medium (mais pesado = mais preciso e mais lento)
WHISPER_MODEL_PATH=./models/whisper
PIPER_MODEL_PATH=./models/piper/pt_BR-faber-medium.onnx
PIPER_MODEL_CONFIG=./models/piper/pt_BR-faber-medium.onnx.json
WAKEWORD_MODEL=alexa
WAKEWORD_THRESHOLD=0.5

# --- Embeddings (sentence-transformers, local/gratuito) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Logging ---
LOG_LEVEL=INFO
